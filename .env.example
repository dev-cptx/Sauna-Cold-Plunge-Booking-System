# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/antigravity_booking"

# ─── NextAuth ────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET=""          # generate: openssl rand -base64 32

# ─── Midtrans ────────────────────────────────────────────
# Get keys from: https://dashboard.sandbox.midtrans.com
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
NEXT_PUBLIC_MIDTRANS_SNAP_URL="https://app.sandbox.midtrans.com/snap/snap.js"

# ─── Email (Resend) ───────────────────────────────────────
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Antigravity <no-reply@yourdomain.com>"

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="Antigravity"

# ─── QR Code Signing ─────────────────────────────────────
QR_SIGNING_SECRET=""        # generate: openssl rand -base64 32

# ─── Initial Admin Seed ──────────────────────────────────
SEED_ADMIN_EMAIL="admin@antigravity.id"
SEED_ADMIN_PASSWORD="Admin123!"
SEED_ADMIN_NAME="Admin"
